{
  "name": "aiuda-puml",
  "productName": "AIuda PUML",
  "version": "1.2.2",
  "description": "PlantUML-editor med AI-stöd och draw.io-export",
  "license": "GPL-2.0-only",
  "author": "Tomas Hultberg",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/download-jre.js",
    "build-jre": "bash scripts/build-jre.sh",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "se.gnossa.aiuda-puml",
    "productName": "AIuda PUML",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns"
    },
    "extraResources": [
      {
        "from": "resources/plantuml.jar",
        "to": "plantuml.jar"
      },
      {
        "from": "resources/jre",
        "to": "jre",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "!src/.env",
      "!src/.env.local",
      "!src/.env.migrerad"
    ],
    "publish": {
      "provider": "github",
      "owner":    "Gnossan",
      "repo":     "aiuda-puml"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
