# AIuda™ PUML — API-nycklar (endast för utveckling)
#
# I den körande appen sparas API-nycklar krypterat via Electrons safeStorage
# (se ⚙ → API-inställningar). Den här .env-filen är bara ett alternativ för
# utvecklare som kör "npm start" och hellre sätter nycklarna som env-variabler
# — kopiera filen till .env och fyll i dina nycklar.
# .env läses av Electron-huvudprocessen — nyckeln skickas aldrig till webbläsaren.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT) — valfritt
# OPENAI_API_KEY=sk-...
